---
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;500;700&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <style is:global>
        :root { 
            --c-negro: #0a0a0a; 
            --c-blanco: #fcfcfc;
            --c-magenta: #ff00ff;
            /* Definición de Tipografías */
            --font-titulo: 'Jost', sans-serif; /* El look Futura */
            --font-cuerpo: 'Lora', serif;      /* El look Georgia */
        }

        html {
            scroll-behavior: smooth;
            overflow-y: scroll;
            height: auto;
        }

        body {
            margin: 0;
            padding: 0;
            background: var(--c-negro);
            color: var(--c-blanco);
            font-family: var(--font-cuerpo); /* Texto por defecto en Serif */
            font-size: 18px;
            line-height: 1.7;
            overflow-x: hidden; 
            min-height: 100%;
            -webkit-font-smoothing: antialiased;
        }

        /* Jerarquía Tipográfica */
        h1, h2, h3, .sans, .badge, .btn-main {
            font-family: var(--font-titulo);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
        }

        p {
            margin-bottom: 1.5rem;
        }

        strong {
            color: var(--c-blanco);
            font-weight: 700;
        }

        /* Clase para el efecto de revelado al bajar */
        .reveal { 
            opacity: 0; 
            transform: translateY(30px); 
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1); 
        }
        .reveal.active { 
            opacity: 1; 
            transform: translateY(0); 
        }
    </style>
</head>
<body>
    <slot />
</body>
</html>