---
import Layout from '../../../layouts/Layout.astro';

const books = [
    {
        title: 'Book Title 1',
        author: 'Author Name',
        year: 2023,
        description: 'A brief description of the book'
    },
    {
        title: 'Book Title 2',
        author: 'Author Name',
        year: 2022,
        description: 'A brief description of the book'
    },
    {
        title: 'Book Title 3',
        author: 'Author Name',
        year: 2021,
        description: 'A brief description of the book'
    }
];
---

<Layout title="Books">
    <main>
        <h1>My Books</h1>
        <ul>
            {books.map((book) => (
                <li>
                    <h2>{book.title}</h2>
                    <p><strong>Author:</strong> {book.author}</p>
                    <p><strong>Year:</strong> {book.year}</p>
                    <p>{book.description}</p>
                </li>
            ))}
        </ul>
    </main>
</Layout>

<style>
    main {
        max-width: 800px;
        margin: 0 auto;
    }
    
    ul {
        list-style: none;
        padding: 0;
    }
    
    li {
        margin-bottom: 2rem;
        padding: 1rem;
        border: 1px solid #ccc;
        border-radius: 8px;
    }
</style>