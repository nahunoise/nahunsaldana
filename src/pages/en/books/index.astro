---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/navbar.astro';

const books = [
    {
        title: 'Book Title 1',
        author: 'Author Name',
        image: '/images/libro-a.jpg', // Reutiliza la misma imagen del folder public
        description: 'A brief description of the book that engages the reader.',
        link: '/en/books/book-1'
    },
    {
        title: 'Book Title 2',
        author: 'Author Name',
        image: '/images/libro-b.jpg',
        description: 'Exploring new frontiers in this compelling volume.',
        link: '/en/books/book-2'
    },
    // Add more books as needed
];
---

<Layout title="My Books">
    <Navbar />
    <main class="container">
        <section class="proyectos">
            <h1 style="text-align: center; margin-top: 40px;">My Books</h1>
            <p style="text-align: center; margin-bottom: 40px;">Explore my personal library and publications.</p>
            
            <div class="proyectos-grid">
                {books.map((book) => (
                    <a href={book.link} class="proyecto">
                        <img src={book.image} alt={book.title} loading="lazy" />
                        <div class="proyecto-texto">
                            <h3>{book.title}</h3>
                            <p>{book.author} — {book.description}</p>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>
</Layout>

<style>
    /* Mantenemos exactamente los mismos estilos para coherencia visual */
    .proyectos-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
        margin-top: 20px;
    }

    @media (min-width: 900px) {
        .proyectos-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .proyecto {
        position: relative;
        overflow: hidden;
        border-radius: 16px;
        display: block;
        text-decoration: none;
        aspect-ratio: 3 / 4;
        background-color: rgba(0,0,0,0.05);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .proyecto:hover {
        transform: scale(1.02);
    }

    .proyecto img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 16px;
    }

    .proyecto-texto {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0, 44, 20, 0.9));
        color: white;
        padding: 30px 20px 20px;
        border-radius: 0 0 16px 16px;
    }

    .proyecto-texto h3 {
        margin: 0;
        font-size: 1.5rem;
        color: #e9f1c6;
    }

    .proyecto-texto p {
        margin: 5px 0 0;
        font-size: 0.9rem;
        opacity: 0.9;
    }
</style>