---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/navbar.astro';

const libros = [
    {
        titulo: 'The Forest and its Turns',
        autor: 'Nahun Saldaña Macedo',
        imagen: '/images/caratula_libro_dsv_2026.jpg', 
        descripcion: 'From an encounter with a viper that ends a childhood game, to designing technological solutions for a future in crisis, The Forest and its Turns invites us to listen to the murmur of the Huallaga river—not as an echo of the past, but as a warning and a message of hope.',
        link: '/en/books/twistsofthewild'
    },
    {
        titulo: 'The Sonic Weaponry of the Asháninka Army',
        autor: 'Nahun Saldaña Macedo',
        imagen: '/images/fanzine-1.jpg',
        descripcion: 'A journey into one of Perus most fascinating stories of resistance. Discover how one of the country’s fiercest warrior communities used the power of sound to defend their territory and culture. A narrative that reflects on resistance and sound as a tool for struggle.',
        link: 'https://amzn.eu/d/0aXb2XXI'
    },
    // Add more books here...
];
---

<Layout title="My Books">
    <Navbar />
    <main class="container">
        <section class="proyectos">
            <h1 style="text-align: center; margin-top: 40px;">My Books</h1>
            <p style="text-align: center; margin-bottom: 40px;">Explore my personal library and publications.</p>
            
            <div class="proyectos-grid">
                {libros.map((libro) => (
                    <a href={libro.link} class="proyecto">
                        <img src={libro.imagen} alt={libro.titulo} loading="lazy" />
                        <div class="proyecto-texto">
                            <h3>{libro.titulo}</h3>
                            <p>{libro.autor} — {libro.descripcion}</p>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>
</Layout>

<style>
    /* Exact design to the version you liked */
    .proyectos-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
        margin-top: 20px;
    }

    @media (min-width: 900px) {
        .proyectos-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .proyecto {
        position: relative;
        overflow: hidden;
        border-radius: 16px;
        display: block;
        text-decoration: none;
        aspect-ratio: 3 / 4;
        background-color: rgba(0,0,0,0.05);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .proyecto:hover {
        transform: scale(1.02);
    }

    .proyecto img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 16px;
    }

    .proyecto-texto {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0, 44, 20, 0.9));
        color: white;
        padding: 30px 20px 20px;
        border-radius: 0 0 16px 16px;
    }

    .proyecto-texto h3 {
        margin: 0;
        font-size: 1.5rem;
        color: #e9f1c6;
    }

    .proyecto-texto p {
        margin: 5px 0 0;
        font-size: 0.9rem;
        opacity: 0.9;
    }
</style>